{
  "expo": {
    "name": "Diaspora Eats",
    "slug": "diaspora-eats",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/diaspora_eats_logo.png",
    "userInterfaceStyle": "automatic",
    "scheme": "diasporaeats",
    "splash": {
      "image": "./assets/images/diaspora_eats_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ooosumfoods.jambalayajerkjollof",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/diaspora_eats_logo.png",
        "backgroundColor": "#000000"
      },
      "package": "com.ooosumfoods.jambalayajerkjollof"
    },
    "web": {
      "favicon": "./assets/images/diaspora_eats_logo.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "11e0cbaf-c71d-4626-9a4f-2fb537e493d9"
      }
    }
  },
  "packageManager": "pnpm@10.11.0"
}
